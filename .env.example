# LLM client: "claude-code" (default, uses your local Claude subscription via the
# Agent SDK — no API key needed) or "api" (metered Anthropic API, requires a key).
LLM_CLIENT=claude-code

# Only needed when LLM_CLIENT=api
ANTHROPIC_API_KEY=sk-ant-...

ANTHROPIC_MODEL=claude-opus-4-7

# Content review pass/fail cutoff (0-100)
REVIEW_SCORE_THRESHOLD=70

# Topic approval cutoff for the trend scorer (0-100)
TOPIC_SCORE_THRESHOLD=60

# Root for the trend-radar folders (inbox/queue/drafts/...). Git-ignored.
WORKSPACE_DIR=./workspace
