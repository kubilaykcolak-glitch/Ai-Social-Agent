# LLM client: "claude-code" (default, uses your local Claude subscription via the
# Agent SDK — no API key needed) or "api" (metered Anthropic API, requires a key).
LLM_CLIENT=claude-code

# Only needed when LLM_CLIENT=api
ANTHROPIC_API_KEY=sk-ant-...

ANTHROPIC_MODEL=claude-opus-4-7

# Content review pass/fail cutoff (0-100)
REVIEW_SCORE_THRESHOLD=70

# Topic approval cutoff for the trend scorer (0-100)
TOPIC_SCORE_THRESHOLD=60

# --- Story mode (serialized AI fiction) ---
# Story arc quality cutoff for the self-critique loop (0-100)
STORY_SCORE_THRESHOLD=75
# Max revision passes if the critic scores an arc below threshold
STORY_MAX_REVISIONS=2

# Root for the trend-radar folders (inbox/queue/drafts/...). Git-ignored.
WORKSPACE_DIR=./workspace

# --- Video generation ---
# Visual source for b-roll: "stock" (Pexels) or "ai"
VISUAL_SOURCE=stock
# Renderer: "ffmpeg" (real, needs ffmpeg installed) or "stub" (placeholder mp4)
VIDEO_RENDERER=ffmpeg
# Pexels stock images (free key from https://www.pexels.com/api/). Empty -> stub visuals.
PEXELS_API_KEY=
# AI image generation (set VISUAL_SOURCE=ai to use). Higgsfield Cloud key+secret from
# https://cloud.higgsfield.ai/ (API section). Needs BOTH; empty -> stub visuals.
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=
HIGGSFIELD_IMAGE_MODEL=flux-pro/kontext/max/text-to-image
HIGGSFIELD_ASPECT=9:16
# Image-prompt template; {SCENE} is replaced with an LLM-written visual description per scene.
# Presets + prompting guide in docs/prompting-templates.md (apocalypse-horror is the default).
HIGGSFIELD_STYLE=cinematic film still. {SCENE}. post-apocalyptic horror atmosphere, desolate and eerie, desaturated teal-and-amber grade, consistent volumetric lighting, god rays through haze, deep low-key shadows, dramatic rim light, fog and drifting ash, shot on ARRI Alexa, 35mm anamorphic lens, f/2.0 shallow depth of field, Kodak Vision3 film grain, rule of thirds, no text, no watermark, no on-screen captions
# ElevenLabs voiceover (https://elevenlabs.io). Empty -> stub TTS.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2

# --- YouTube upload (real publishing) ---
# Create an OAuth client (Desktop app) in Google Cloud + enable the YouTube Data API v3.
# Then run: node apps/orchestrator/dist/youtube-auth-cli.js  (prints a consent URL),
# approve, and re-run with --code=<code> to get YOUTUBE_REFRESH_TOKEN.
# Empty creds -> stub uploader (no real upload). Uploads default to private (review in Studio).
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_DEFAULT_VISIBILITY=private
